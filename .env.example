VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Geen externe favicon-requests (Google/DDG) voor goede-doelen-logo’s — alleen sector-emoji; minder mislukte requests in Network.
# VITE_SKIP_EXTERNAL_CAUSE_LOGOS=1

# Edge Function secrets (Supabase Dashboard → Project Settings → Edge Functions — niet in Vite zetten):
# AZURE_CONTENT_SAFETY_ENDPOINT=https://YOUR-NAME.cognitiveservices.azure.com
# AZURE_CONTENT_SAFETY_KEY=...
# AZURE_IMAGE_REJECT_SEVERITY=4   (optioneel; weiger bij severity 4 of 6 voor Hate/Sexual/Violence/SelfHarm)
# Optioneel: publieke site-URL voor Supabase redirect (wachtwoord reset); moet ook in Supabase Auth → Redirect URLs staan.
# VITE_SITE_URL=https://www.donatie.eu
# Lokaal testen op je telefoon (zelfde WiFi): zet hier http://192.168.x.x:5173 en voeg diezelfde URL + /auth/reset-password toe bij Supabase Redirect URLs.
# VITE_SITE_URL=http://192.168.1.10:5173
